DB_URL=your_mongodb_connection_string

CLIENT_URL=your_frontend_url

EMAIL_SERVICE=gmail
EMAIL_USER=[your_email@example.com](mailto:your_email@example.com)
EMAIL_PASS=your_email_app_password

RESEND_API_KEY=your_resend_api_key

# CORS Configuration - comma-separated list of allowed origins

ALLOWED_ORIGINS=[http://localhost:5173,http://localhost:3000,https://your-domain.com](http://localhost:5173,http://localhost:3000,https://your-domain.com)

# Server Port

PORT=5002

LEADERBOARD_API_URL=https://your-api-url.com/api/contributors/sync
LEADERBOARD_API_TOKEN=your_api_token
